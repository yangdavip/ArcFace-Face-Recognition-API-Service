# Database Configuration (可选，环境变量优先)
# DATABASE_URL: 覆盖 config.yaml 中的数据库配置
# 示例:
#   sqlite: sqlite:///./face_recognition.db
#   postgresql://user:password@localhost:5432/dbname
# DATABASE_URL=

# API Authentication (留空则不启用鉴权，适用于开发环境)
# API_KEY=your-secret-api-key

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
